{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": ["src"]
}