generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

enum ProjectVisibility {
  PRIVATE
  TEAM
  PUBLIC
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ActivityType {
  TEAM_CREATED

  PROJECT_CREATED

  PROJECT_MEMBER_ADDED
  PROJECT_MEMBER_REMOVED

  FILE_CREATED
  FILE_RENAMED
  FILE_MOVED
  FILE_DELETED

  FOLDER_CREATED
  FOLDER_RENAMED
  FOLDER_MOVED
  FOLDER_DELETED

  FILE_RESTORED

  PROJECT_OWNERSHIP_TRANSFERRED
}

model User {
  id String @id @default(cuid())

  email    String @unique
  username String @unique
  password String

  role Role @default(USER)

  isEmailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  teamMemberships    TeamMember[]
  projectMemberships ProjectMember[]

  ownedTeams Team[] @relation("TeamOwner")

  invitationsSent TeamInvite[] @relation("InviteSender")
  teamInvites     TeamInvite[]
  acceptedInvites TeamInvite[] @relation("AcceptedInvite")

  ownedProjects       Project[]       @relation("ProjectOwner")
  createdProjects     Project[]       @relation("ProjectCreator")
  projectMembersAdded ProjectMember[] @relation("ProjectMemberAddedBy")

  createdFiles File[] @relation("FileCreator")
  updatedFiles File[] @relation("FileUpdater")

  createdFileVersions FileVersion[] @relation("FileVersionCreator")
  activityLogs        ActivityLog[]
}

model Team {
  id String @id @default(cuid())

  name String
  slug String @unique

  description String?

  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TeamMember[]
  projects     Project[]
  invites      TeamInvite[]
  activityLogs ActivityLog[]

  @@index([slug])
}

model TeamMember {
  id String @id @default(cuid())

  teamId String
  userId String

  role TeamRole @default(MEMBER)

  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Project {
  id String @id @default(cuid())

  name String
  slug String

  description String?

  visibility ProjectVisibility @default(PRIVATE)
  status     ProjectStatus     @default(ACTIVE)

  createdById String

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdBy User @relation("ProjectCreator", fields: [createdById], references: [id])

  memberships ProjectMember[]

  folders Folder[]
  files   File[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@index([ownerId])
  @@index([createdById])
}

model ProjectMember {
  id String @id @default(cuid())

  projectId String
  userId    String

  role ProjectRole @default(VIEWER)

  addedById String?
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  addedBy User? @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([addedById])
}

model TeamInvite {
  id String @id @default(cuid())

  email String

  token String @unique

  role TeamRole @default(MEMBER)

  expiresAt DateTime

  accepted     Boolean   @default(false)
  acceptedById String?
  acceptedBy   User?     @relation("AcceptedInvite", fields: [acceptedById], references: [id])
  acceptedAt   DateTime?

  createdAt DateTime @default(now())

  teamId String

  invitedById String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  invitedBy User    @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])
  userId    String?

  @@unique([teamId, email])
  @@index([teamId])
  @@index([email])
}

model Folder {
  id String @id @default(cuid())

  name String

  projectId String
  parentId  String?

  createdById String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parent Folder? @relation("FolderHierarchy", fields: [parentId], references: [id])

  children Folder[] @relation("FolderHierarchy")

  files File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, parentId, name])
  @@index([projectId])
  @@index([parentId])
}

model File {
  id String @id @default(cuid())

  name String

  extension String?

  content String @default("")

  projectId String
  folderId  String?

  lastOpenedAt DateTime?

  createdById String
  updatedById String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  folder Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  createdBy User @relation("FileCreator", fields: [createdById], references: [id])

  updatedBy User @relation("FileUpdater", fields: [updatedById], references: [id])

  versions FileVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, folderId, name, extension])
  @@index([projectId])
  @@index([folderId])
}

model FileVersion {
  id String @id @default(cuid())

  fileId String

  version Int

  content String

  createdById String

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  createdBy User @relation("FileVersionCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@unique([fileId, version])
  @@index([fileId])
}

model ActivityLog {
  id String @id @default(cuid())

  type ActivityType

  message String

  userId String

  projectId String?

  teamId String?

  metadata Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([teamId])
  @@index([createdAt])
}

model Session {
  id String @id @default(cuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String

  userAgent String?
  ipAddress String?

  expiresAt DateTime

  createdAt DateTime @default(now())
}

model VerificationToken {
  id String @id @default(cuid())

  token String

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id String @id @default(cuid())

  token String

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())
}
